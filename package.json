{
  "name": "playwrightplayground",
  "version": "1.0.0",
  "description": "Repo for practicing playwright",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "playwright test",
    "test:api": "npx playwright test tests/practice1/api.spec.ts",
    "test:ui": "npx playwright test tests/practice2/ui.spec.ts",
    "prepare": "husky",
        "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TomiMan7/playwrightPlayground.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/TomiMan7/playwrightPlayground/issues"
  },
  "homepage": "https://github.com/TomiMan7/playwrightPlayground#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "allure-playwright": "^3.10.2",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.5",
    "typescript-eslint": "^8.62.0"
  },
  "lint-staged": {
    "**/*.{js,ts}": [
      "eslint --fix",
      "git add"
    ]
  }
}
